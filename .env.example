# ============================================================
# itc-node-rs — operator environment template
# Copy to /etc/itc-node-rs/env (or .env in the working dir)
# and fill in the values marked with <…>.
# ============================================================

# ── Node data directory ──────────────────────────────────────
ITC_NODE_DATADIR=/var/lib/itc-node-rs

# ── Bridge oracle ────────────────────────────────────────────
# Plain bech32 ITC address of the bridge lock wallet.
# The oracle decodes this automatically — no manual hash160 needed.
ITC_BRIDGE_ADDRESS=itc1q<your_bridge_address_here>

# Governance fee deducted before minting aITC (basis points, 1 BPS = 0.01%).
# Default: 500 (5%).  Maximum: 1000 (10%).
ITC_BRIDGE_FEE_BPS=500

# L1 confirmations required before minting aITC.  Default: 6.
ITC_BRIDGE_CONFIRMATIONS=2

# ── Anchor poster ────────────────────────────────────────────
# WIF-encoded secp256k1 private key of the funded anchor wallet.
# The P2PKH address is derived automatically from this key.
ITC_ANCHOR_WIF=<your_wif_encoded_anchor_private_key>

# Epochs between anchor posts.  Default: 100.
ITC_ANCHOR_INTERVAL=100

# ── ITC L1 JSON-RPC (used by the anchor poster for UTXO auto-discovery) ──────
# The poster calls `listunspent` on this endpoint to select the best available
# UTXO — no manual UTXO lookup needed.
ITC_L1_RPC_URL=http://127.0.0.1:9332
ITC_L1_RPC_USER=<your_rpc_username>
ITC_L1_RPC_PASS=<your_rpc_password>

# ── Optional: static UTXO override ───────────────────────────
# Uncomment and fill these in ONLY if you want to bypass auto-discovery
# (e.g. air-gapped setup, testnet without a local node, or debugging).
# All three must be set together; partial settings produce a warning.
#
# ITC_ANCHOR_UTXO_TXID=<64-char-hex-txid>
# ITC_ANCHOR_UTXO_VOUT=0
# ITC_ANCHOR_UTXO_VALUE=<satoshis>

# ── Legacy (kept for backwards compatibility) ─────────────────
# ITC_BRIDGE_HASH160 is still accepted if ITC_BRIDGE_ADDRESS is not set.
# Prefer ITC_BRIDGE_ADDRESS for new deployments.
#
# ITC_BRIDGE_HASH160=<40-char-hex-hash160>
